@{
    var path = Context.Request.Path.Value;
    bool esInicio = path == "/";
    bool esAerolinea = path.Contains("AerolineasActivas");
    bool esAvion = path.Contains("Aviones");
    bool esPropietario = path.Contains("Propietarios");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AerolineasWEB</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/AerolineasWEB.UI.styles.css" asp-append-version="true" />
    @* <link href="https://cdn.datatables.net/v/dt/dt-2.3.5/datatables.min.css" rel="stylesheet" integrity="sha384-Lv8lYSJkh1Hc5kB9lk2YbbGdchMRCuAcwUOYWZ3Q/YIfKNVW+6W+V57wxKNv1D8l" crossorigin="anonymous"> *@
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/core@1.4.0/dist/css/tabler.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/cd979c0049.js" crossorigin="anonymous"></script>
    
    <link href="https://cdn.jsdelivr.net/gh/StephanWagner/jBox@v1.3.3/dist/jBox.all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.5.2/dist/css/tom-select.css" rel="stylesheet">
</head>
<body>
    <header class="navbar navbar-expand-md d-print-none">
        <div class="container-xl">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbar-menu" aria-controls="navbar-menu"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <!-- BEGIN NAVBAR LOGO --><a asp-controller="Home" asp-action="Index" aria-label="Airelys"
                                         class="navbar-brand navbar-brand-autodark me-3">
                <img src="~/img/LOGO.png" alt="Logo" width="90" /><span class="text-primary">AIRELYS</span>
            </a><!-- END NAVBAR LOGO -->
            <ul class="navbar-nav">
                <li class="nav-item @(esInicio ? "active" : "")">
                    <a class="nav-link" asp-controller="Home" asp-action="Index" >
                        <span class="nav-link-icon">
                            <!-- Download SVG icon from http://tabler.io/icons/icon/home -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                 class="icon icon-1">
                                <path d="M5 12l-2 0l9 -9l9 9l-2 0" />
                                <path d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-7" />
                                <path d="M9 21v-6a2 2 0 0 1 2 -2h2a2 2 0 0 1 2 2v6" />
                            </svg>
                        </span>
                        <span class="nav-link-title"> Inicio </span>
                    </a>
                </li>
                <li class="nav-item @(esAerolinea ? "active" : "")">
                    <a class="nav-link" asp-controller="AerolineasActivas" asp-action="Index">
                        <span class="nav-link-icon">
                            <!-- Download SVG icon from http://tabler.io/icons/icon/checkbox -->
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-buildings"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M4 21v-15c0 -1 1 -2 2 -2h5c1 0 2 1 2 2v15" /><path d="M16 8h2c1 0 2 1 2 2v11" /><path d="M3 21h18" /><path d="M10 12v.01" /><path d="M10 16v.01" /><path d="M10 8v.01" /><path d="M7 12v.01" /><path d="M7 16v.01" /><path d="M7 8v.01" /><path d="M17 12v.01" /><path d="M17 16v.01" /></svg>
                        </span>
                        <span class="nav-link-title"> Aerolíneas </span>
                    </a>
                </li>
                <li class="nav-item @(esAvion ? "active" : "")">
                    <a class="nav-link" asp-controller="AvionesActivos" asp-action="Index">
                        <span class="nav-link-icon">
                            <!-- Download SVG icon from http://tabler.io/icons/icon/checkbox -->
                            <i class="fa-solid fa-plane"></i>
                        </span>
                        <span class="nav-link-title"> Aviones </span>
                    </a>
                </li>
                <li class="nav-item @(esPropietario ? "active" : "")">
                    <a class="nav-link" asp-controller="PropietariosActivos" asp-action="Index">
                        <span class="nav-link-icon">
                            <!-- Download SVG icon from http://tabler.io/icons/icon/checkbox -->
                            <i class="fa-solid fa-users"></i>
                        </span>
                        <span class="nav-link-title"> Propietarios </span>
                    </a>
                </li>
            </ul>
            <div class="navbar-nav flex-row order-md-last ms-auto">
                <div class="nav-item dropdown">
                    <a href="#" class="nav-link d-flex lh-1 text-reset"
                       data-bs-toggle="dropdown" aria-label="Open user menu">
                        <span class="avatar avatar-sm"
                              style="background-image: url('@Url.Content("~/img/user.jpg")')"></span>
                        <div class="d-none d-xl-block ps-2">
                            <div>Valeria Carvajal</div>
                            <div class="mt-1 small text-secondary">Desarrolladora</div>
                        </div>
                    </a>
                    <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                        <a href="#" class="dropdown-item">Status</a>
                        <a href="./profile.html" class="dropdown-item">Profile</a>
                        <a href="#" class="dropdown-item">Feedback</a>
                        <div class="dropdown-divider"></div>
                        <a href="./settings.html" class="dropdown-item">Settings</a>
                        <a href="./sign-in.html" class="dropdown-item">Logout</a>
                    </div>
                </div>
            </div>
        </div>
    </header>
    <div class="container-xl">
        <main role="main" class="pb-3 pt-5 main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer footer-transparent d-print-none mt-auto position-static">
        <div class="container-xl">
            <div class="row align-items-center">

                <!-- Izquierda -->
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <div class="text-secondary fs-3 lh-1">
                        © @DateTime.Now.Year <span>Todos los derechos reservados</span>
                    </div>
                    <div class="text-secondary fs-3 lh-1 mt-3">
                        Elaborado con <span class="heart"><i class="fa-solid fa-heart"></i></span> por
                        <span class="text-primary fw-semibold">Valeria Carvajal Mayorga</span>
                    </div>
                </div>

                <!-- Derecha -->
                <div class="col-md-6 text-center text-md-end">
                    <a href="mailto:valeriacarvajal1@outlook.com.com" class="footer-btn me-2">
                        <i class="fa-solid fa-envelope"></i> Correo
                    </a>
                    <a href="https://github.com/vale18carvajal/AerolineasWEB.git" target="_blank" class="footer-btn">
                        <i class="fa-brands fa-github"></i> GitHub
                    </a>
                </div>

            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/imask"></script>
    @* <script src="https://cdn.datatables.net/v/dt/dt-2.3.5/datatables.min.js" integrity="sha384-qH0inyYSCOpaLgM/WSarLVnq0ULwworkGFzUI+E6bpx0DUCIsJePT0TRDnLnkcU1" crossorigin="anonymous"></script> *@
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@tabler/core@1.4.0/dist/js/tabler.min.js"></script>
   
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @* <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/gh/StephanWagner/jBox@v1.3.3/dist/jBox.all.min.js"></script> *@
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.5.2/dist/js/tom-select.complete.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
